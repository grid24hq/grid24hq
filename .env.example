# ─── Firebase ────────────────────────────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Resend (email) ───────────────────────────────────────────────────────────
# NOOIT in de frontend! Alleen in Cloudflare Worker gebruiken.
# resend.com → API Keys
RESEND_API_KEY=

# ─── Race API ─────────────────────────────────────────────────────────────────
VITE_RACE_API_BASE_URL=https://api.grid24hq.pages.dev
VITE_RACE_API_KEY=

# ─── Weather (Open-Meteo — gratis, geen key nodig) ───────────────────────────
VITE_WEATHER_API_BASE_URL=https://api.open-meteo.com/v1
